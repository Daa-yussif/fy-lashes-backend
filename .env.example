# ── Server ──────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ──────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/fy-lashes

# ── JWT ──────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# ── Admin credentials ────────────────────────────────
ADMIN_EMAIL=admin@fylashes.com
ADMIN_PASSWORD=Admin@1234

# ── CORS ─────────────────────────────────────────────
CLIENT_URL=http://localhost:5500

# ── File uploads ─────────────────────────────────────
MAX_FILE_SIZE_MB=5